rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function orgSettingsDoc() {
      return get(/databases/$(database)/documents/orgSettings/main);
    }

    function mfaRequired() {
      return orgSettingsDoc().exists() && orgSettingsDoc().data.mfaEnabled == true;
    }

    function mfaWindowFresh(userData) {
      return (userData.devUser == true)
        ? userData.mfaVerifiedAt > request.time - duration.value(4, 'h')
        : userData.mfaVerifiedAt > request.time - duration.value(24, 'h');
    }

    // Narrow carve-out: the controlled dev account
    // (dev@communitybridge.app, with devUser==true on its profile) is exempt
    // from the MFA gate so the dev switcher can navigate the full hierarchy
    // in any environment. Everyone else still requires a fresh mfaVerifiedAt.
    function isDevBypassUser() {
      return signedIn() && userDoc().exists() &&
        userDoc().data.devUser == true &&
        userDoc().data.email == 'dev@communitybridge.app';
    }

    function mfaVerified() {
      return !mfaRequired() || isDevBypassUser() || (
        signedIn() &&
        userDoc().exists() &&
        (userDoc().data.mfaVerifiedAt is timestamp) &&
        mfaWindowFresh(userDoc().data)
      );
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && userDoc().exists() &&
        (userDoc().data.role == 'admin' || userDoc().data.role == 'administrator');
    }

    function isScopedAdmin() {
      return signedIn() && userDoc().exists() &&
        (userDoc().data.role == 'admin' ||
         userDoc().data.role == 'administrator' ||
         userDoc().data.role == 'superAdmin' ||
         userDoc().data.role == 'superadmin' ||
         userDoc().data.role == 'orgAdmin' ||
         userDoc().data.role == 'orgadmin' ||
         userDoc().data.role == 'campusAdmin' ||
         userDoc().data.role == 'campusadmin');
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());

      // Users may create their own profile on first sign-in.
      allow create: if signedIn() && request.auth.uid == uid &&
        (
          request.resource.data.role == 'parent' ||
          request.resource.data.role == 'faculty' ||
          request.resource.data.role == 'therapist' ||
          request.resource.data.role == 'bcba'
        );

      // Users may update their own profile, but may not change role.
      allow update: if signedIn() && request.auth.uid == uid &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.mfaVerifiedAt == resource.data.mfaVerifiedAt;

      // Allow users to delete their own profile (for account deletion flows).
      allow delete: if signedIn() && request.auth.uid == uid;
    }

    match /directoryLinks/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());

      // Allow a parent user to create/update their own link only when it points to their own uid.
      allow create, update: if signedIn() && request.auth.uid == uid &&
        request.resource.data.role == 'parent' &&
        request.resource.data.parentId == uid;

      // All other link mutations are admin-only.
      allow create, update: if isAdmin();

      // Allow users to delete their own self-owned link.
      allow delete: if isAdmin() || (
        signedIn() && request.auth.uid == uid &&
        resource.data.role == 'parent' &&
        resource.data.parentId == uid
      );
    }

    match /parents/{id} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == id);
      allow create, update: if isAdmin() || (signedIn() && request.auth.uid == id);
      allow delete: if isAdmin() || (signedIn() && request.auth.uid == id);
    }

    match /therapists/{id} {
      allow read: if mfaVerified() && (isAdmin() || request.auth.uid == id);
      allow create, update, delete: if isAdmin();
    }

    match /children/{id} {
      allow read: if mfaVerified() && (isAdmin() || (signedIn() && (request.auth.uid in (resource.data.parentIds || []))));
      allow create, update, delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read, create, update, delete: if false;

      match /comments/{commentId} {
        allow read, create, update, delete: if false;
      }
    }

    match /messages/{messageId} {
      allow read: if mfaVerified() && (
        isAdmin() ||
        (request.auth.uid in (resource.data.participantUids || [])) ||
        (isAdmin() && ('admin' in (resource.data.toRoles || [])))
      );

      allow create: if mfaVerified() &&
        (request.auth.uid in (request.resource.data.participantUids || [])) &&
        request.resource.data.sender.id == request.auth.uid;

      allow update, delete: if false;
    }

    match /urgentMemos/{memoId} {
      allow read: if mfaVerified() && (
        isAdmin() ||
        resource.data.proposerUid == request.auth.uid ||
        resource.data.proposerId == request.auth.uid ||
        request.auth.uid in (resource.data.recipientIds || [])
      );
      allow create: if isAdmin();

      // Allow users to record their response status; admins can update full memos.
      allow update: if mfaVerified() && (
        isAdmin() ||
        ((
          resource.data.proposerUid == request.auth.uid ||
          resource.data.proposerId == request.auth.uid ||
          request.auth.uid in (resource.data.recipientIds || [])
        ) && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'respondedAt']))
      );

      allow delete: if isAdmin();

      match /reads/{uid} {
        allow read, create, update: if mfaVerified() && request.auth.uid == uid;
        allow delete: if false;
      }
    }

    match /timeChangeProposals/{proposalId} {
      allow read: if mfaVerified() && (isAdmin() || (signedIn() && resource.data.proposerUid == request.auth.uid));
      allow create: if mfaVerified() && request.resource.data.proposerUid == request.auth.uid;

      // Allow admins to respond; proposer may not change after creation.
      allow update: if mfaVerified() && (isAdmin() || (signedIn() &&
        resource.data.proposerUid == request.auth.uid &&
        request.resource.data.proposerUid == resource.data.proposerUid));

      allow delete: if isAdmin();
    }

    match /arrivalPings/{pingId} {
      allow read: if isAdmin();
      allow create: if signedIn() && mfaVerified();
      allow update, delete: if false;
    }

    match /pushTokens/{tokenId} {
      allow read: if isAdmin();
      allow create, update: if signedIn() && request.resource.data.userUid == request.auth.uid;
      allow delete: if signedIn() && resource.data.userUid == request.auth.uid;
    }

    match /orgSettings/{id} {
      allow read, write: if false;
    }

    match /staffWorkspaces/{uid} {
      allow read: if mfaVerified() && (isScopedAdmin() || request.auth.uid == uid);
      allow create, update: if mfaVerified() && (isScopedAdmin() || request.auth.uid == uid);
      allow delete: if isScopedAdmin();
    }

    match /exportJobs/{jobId} {
      allow read: if mfaVerified() && (isScopedAdmin() || resource.data.requesterUid == request.auth.uid);
      allow create: if mfaVerified() && request.resource.data.requesterUid == request.auth.uid;
      allow update: if mfaVerified() && (isScopedAdmin() || resource.data.requesterUid == request.auth.uid);
      allow delete: if isScopedAdmin();
    }

    match /programEditorWorkspaces/{programId} {
      allow read: if mfaVerified() && signedIn();
      allow create, update: if mfaVerified() && isScopedAdmin();
      allow delete: if isScopedAdmin();
    }

    match /meta/{id} {
      allow read, write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
