rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        (userDoc().data.role == 'admin' || userDoc().data.role == 'administrator');
    }

    match /uploads/{uid}/{allPaths=**} {
      // Private-by-default: only the owner (or admin) can read/write.
      allow read, write: if signedIn() && (request.auth.uid == uid || isAdmin());
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
