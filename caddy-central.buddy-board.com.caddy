# BuddyBoard routing for a central Caddy instance
#
# Paste this block into your central Caddyfile.
#
# If your CommunityBridge API runs on the same machine as Caddy, prefer proxying to localhost.
# If it runs on a different host, replace 127.0.0.1 with that host's IP/DNS.

buddy-board.com {
  encode zstd gzip

  @api path /api/* /uploads/*
  handle @api {
    reverse_proxy 127.0.0.1:3005
  }

  handle {
    reverse_proxy 127.0.0.1:3005
  }
}
