# Keep EAS upload tarballs small and avoid bundling transient artifacts.

.git/
.expo/
.vscode/
.firebase/
.agents/

env/

node_modules/

dist/
build/
tmp/
web/
web-dist/

# Firebase Hosting / Expo web export output is not needed for native EAS builds.
public/**
!public/icon.png
!public/cblogo.png
!public/favicon.ico

# Server-side and packaging artifacts are not used by the mobile app build.
functions/
BuddyBoard_Client_Packet/

android/**/build/
ios/**/build/

.data/

# Local secrets and ad-hoc artifacts
*.p8
client_secret*.json
tmp-login.json
CommBridge.txt
domainPaths.txt

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*