{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": [
    {
      "target": "marketing",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*"
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        },
        {
          "source": "**",
          "headers": [
            { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
            { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
            { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
            { "key": "Content-Security-Policy-Report-Only", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://www.googletagmanager.com https://apis.google.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.googleusercontent.com https://www.gstatic.com; font-src 'self' data:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://*.cloudfunctions.net https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://firestore.googleapis.com https://firebasestorage.googleapis.com https://*.run.app; frame-src https://*.firebaseapp.com https://accounts.google.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'" }
          ]
        }
      ],
      "cleanUrls": true,
      "trailingSlash": false
      ,
      "rewrites": [
        {
          "source": "/api/**",
          "run": {
            "serviceId": "communitybridge",
            "region": "us-central1"
          }
        },
        {
          "source": "/uploads/**",
          "run": {
            "serviceId": "communitybridge",
            "region": "us-central1"
          }
        },
        {
          "source": "/organizations-intake-submit",
          "run": {
            "serviceId": "communitybridge",
            "region": "us-central1"
          }
        },
        {
          "source": "/organizations-intake-config",
          "run": {
            "serviceId": "communitybridge",
            "region": "us-central1"
          }
        },
        {
          "source": "/organizations-intake-action",
          "run": {
            "serviceId": "communitybridge",
            "region": "us-central1"
          }
        },
        {
          "source": "/organizations",
          "destination": "/organizations/index.html"
        },
        {
          "source": "/organizations/**",
          "destination": "/organizations/index.html"
        },
        {
          "source": "/app-login",
          "destination": "/app-login/index.html"
        },
        {
          "source": "/app-login/**",
          "destination": "/app-login/index.html"
        },
        {
          "source": "/delete-account",
          "destination": "/delete-account/index.html"
        },
        {
          "source": "/delete-account/**",
          "destination": "/delete-account/index.html"
        },
        {
          "source": "/dashboard",
          "destination": "/dashboard/index.html"
        },
        {
          "source": "/dashboard/**",
          "destination": "/dashboard/index.html"
        },
        {
          "source": "/home",
          "destination": "/home/index.html"
        },
        {
          "source": "/home/**",
          "destination": "/home/index.html"
        }
      ]
    },
    {
      "target": "app",
      "public": "web-dist",
      "ignore": [
        "firebase.json",
        "**/.*"
      ],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        },
        {
          "source": "**/_expo/static/**/*.@(js|css|map)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        },
        {
          "source": "**",
          "headers": [
            { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
            { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
            { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
            { "key": "Content-Security-Policy-Report-Only", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.gstatic.com https://apis.google.com https://*.sentry-cdn.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.googleusercontent.com https://www.gstatic.com https://firebasestorage.googleapis.com; font-src 'self' data:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://*.cloudfunctions.net https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://firestore.googleapis.com https://firebasestorage.googleapis.com https://*.run.app https://*.ingest.sentry.io https://*.ingest.us.sentry.io; frame-src https://*.firebaseapp.com https://accounts.google.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'" }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/api/**",
          "run": {
            "serviceId": "communitybridge",
            "region": "us-central1"
          }
        },
        {
          "source": "/uploads/**",
          "run": {
            "serviceId": "communitybridge",
            "region": "us-central1"
          }
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
