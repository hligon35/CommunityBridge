{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": [
    {
      "target": "marketing",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*"
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        }
      ],
      "cleanUrls": true,
      "trailingSlash": false
      ,
      "rewrites": [
        {
          "source": "/api/**",
          "run": {
            "serviceId": "communitybridge",
            "region": "us-central1"
          }
        },
        {
          "source": "/uploads/**",
          "run": {
            "serviceId": "communitybridge",
            "region": "us-central1"
          }
        },
        {
          "source": "/app-login",
          "destination": "/app-login/index.html"
        },
        {
          "source": "/app-login/**",
          "destination": "/app-login/index.html"
        },
        {
          "source": "/delete-account",
          "destination": "/delete-account/index.html"
        },
        {
          "source": "/delete-account/**",
          "destination": "/delete-account/index.html"
        },
        {
          "source": "/dashboard",
          "destination": "/dashboard/index.html"
        },
        {
          "source": "/dashboard/**",
          "destination": "/dashboard/index.html"
        },
        {
          "source": "/home",
          "destination": "/home/index.html"
        },
        {
          "source": "/home/**",
          "destination": "/home/index.html"
        }
      ]
    },
    {
      "target": "app",
      "public": "web-dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        },
        {
          "source": "**/_expo/static/**/*.@(js|css|map)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/api/**",
          "run": {
            "serviceId": "communitybridge",
            "region": "us-central1"
          }
        },
        {
          "source": "/uploads/**",
          "run": {
            "serviceId": "communitybridge",
            "region": "us-central1"
          }
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
