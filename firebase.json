{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": [
    {
      "site": "communitybridge-26apr",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*"
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        }
      ],
      "cleanUrls": true,
      "trailingSlash": false
      ,
      "rewrites": [
        {
          "source": "/api/**",
          "run": {
            "serviceId": "buddyboard",
            "region": "us-central1"
          }
        },
        {
          "source": "/uploads/**",
          "run": {
            "serviceId": "buddyboard",
            "region": "us-central1"
          }
        },
        {
          "source": "/home",
          "destination": "/home/index.html"
        },
        {
          "source": "/home/**",
          "destination": "/home/index.html"
        }
      ]
    },
    {
      "site": "communitybridge-26apr20",
      "public": "web-dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        }
      ],
      "cleanUrls": true,
      "trailingSlash": false,
      "rewrites": [
        {
          "source": "/api/**",
          "run": {
            "serviceId": "buddyboard",
            "region": "us-central1"
          }
        },
        {
          "source": "/uploads/**",
          "run": {
            "serviceId": "buddyboard",
            "region": "us-central1"
          }
        },
        {
          "source": "/app-login",
          "destination": "/app-login/index.html"
        },
        {
          "source": "/app-login/**",
          "destination": "/app-login/index.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
